import os, pathlib, numpy as np, pandas as pd, matplotlib.pyplot as plt, shap
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier

TOP_K, MAX_SAMPLE, RND_STATE = 20, 1000, 42
plt.rcParams.update({
    "font.family":"Times New Roman", "axes.labelsize":14,
    "axes.titlesize":14, "xtick.labelsize":14, "ytick.labelsize":14
})

csv_path = r"D:\studysoft\VScode_project\paper3\P3_sample1500.csv"
df = pd.read_csv(csv_path); y = df['landcover']
X  = df.drop(columns='landcover').select_dtypes(include='number')

X_tr, X_val, y_tr, y_val = train_test_split(
    X, y, test_size=0.3, random_state=RND_STATE, stratify=y
)

rf = RandomForestClassifier(n_estimators=50, random_state=RND_STATE, n_jobs=-1).fit(X_tr, y_tr)

rank_X = X_val.sample(n=min(MAX_SAMPLE, len(X_val)), random_state=RND_STATE)\
              .reset_index(drop=True)   # ★ 与蜂巢图同源

explainer = shap.Explainer(rf, X_tr, model_output="probability")
shap_full = explainer(rank_X, check_additivity=False)

vals_signed = shap_full.values.sum(axis=2)
top_idx     = np.argsort(np.abs(vals_signed).mean(0))[::-1][:TOP_K]
top_feats   = X.columns[top_idx].tolist()

shap_top = shap.Explanation(
    values      = vals_signed[:, top_idx],
    base_values = shap_full.base_values.mean(1),
    data        = shap_full.data[:, top_idx],
    feature_names=top_feats
)

plt.figure(figsize=(10,6))
shap.plots.heatmap(
    shap_top, feature_order=list(range(TOP_K)),
    max_display=TOP_K, show=False
)

# 保存到指定目录
out_dir = pathlib.Path(r"C:\Users\10655\Desktop\test")
out_dir.mkdir(parents=True, exist_ok=True)
plt.savefig(out_dir / f"Heatmap_SHAP_Top{TOP_K}.png", dpi=300, bbox_inches="tight")
plt.show()
